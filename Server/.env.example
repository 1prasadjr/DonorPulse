# Server runtime
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Upload controls
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=src/temp/uploads

# Python inference bridge
PYTHON_EXECUTABLE=python
PYTHON_ENTRYPOINT=python/infer_donor_churn.py
PYTHON_TIMEOUT_MS=120000

# Model artifacts
MODEL_DIR=models
TOP_RISK_LIMIT_DEFAULT=25
TOP_RISK_LIMIT_MAX=100
